{
  "uid": "nbu-dataprotection",
  "title": "NetBackup \u2014 Protection des donn\u00e9es / Data Protection",
  "tags": [
    "netbackup",
    "nbu",
    "backup"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "refresh": "1m",
  "links": [
    {
      "type": "dashboards",
      "title": "NetBackup",
      "tags": [
        "netbackup"
      ],
      "asDropdown": true,
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": {},
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "type": "dashboard",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "iconColor": "red"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Alertes / Alerts",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "barchart",
      "id": 2,
      "title": "Alertes par s\u00e9v\u00e9rit\u00e9 / Alerts by severity",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": {
          "showLegend": false
        },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (severity) (nbu_alerts_count)",
          "legendFormat": "{{severity}}",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "id": 3,
      "title": "Alertes par cat\u00e9gorie / Alerts by category",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (category, severity) (nbu_alerts_count)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "job": true,
              "instance": true
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "id": 4,
      "title": "Malware / Malware",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Fichiers scann\u00e9s vs infect\u00e9s / Files scanned vs infected",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            },
            "lineWidth": 1
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "nbu_malware_files_scanned",
          "legendFormat": "scann\u00e9s / scanned",
          "range": true,
          "instant": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "nbu_malware_files_infected",
          "legendFormat": "infect\u00e9s / infected",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "id": 6,
      "title": "Statut des scans / Scan status",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": {
          "showLegend": false
        },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (status) (nbu_malware_scan_count)",
          "legendFormat": "{{status}}",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 7,
      "title": "Catalogue & SLO / Catalog & SLO",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "barchart",
      "id": 8,
      "title": "Posture malware / Malware posture",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": {
          "showLegend": false
        },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (malware_status) (nbu_catalog_images_count)",
          "legendFormat": "{{malware_status}}",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "id": 9,
      "title": "Posture anomalies / Anomaly posture",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 8,
        "y": 19,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": {
          "showLegend": false
        },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (anomaly_status) (nbu_catalog_images_count)",
          "legendFormat": "{{anomaly_status}}",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 10,
      "title": "SLO configur\u00e9s / Configured SLOs",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 16,
        "y": 19,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(nbu_slo_count)",
          "legendFormat": "",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
